# Baza danych PostgreSQL
# Lokalnie: postgresql://postgres:password@localhost:5432/pantera
# Na produkcji (cPanel nie ma Postgresa) — użyj darmowego serwisu:
#   https://neon.tech  lub  https://supabase.com
DATABASE_URL=postgresql://user:password@host:5432/pantera

# Payload — wygeneruj losowy ciąg znaków (min. 32 znaki)
PAYLOAD_SECRET=zmien-na-losowy-ciag-znakow-min-32-znaki

# tpay (zostaw puste żeby działał tryb dev z mock redirect)
TPAY_CLIENT_ID=
TPAY_CLIENT_SECRET=
TPAY_NOTIFICATION_EMAIL=

# URL publiczny strony (bez trailing slash)
NEXT_PUBLIC_SITE_URL=https://twoja-domena.pl

# Node.js
NODE_ENV=production
